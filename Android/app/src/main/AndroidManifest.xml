<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <!-- ── Permissions ─────────────────────────────────────────────── -->

    <!-- UPI / Bank SMS interception -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- App usage stats (requires special grant in Settings) -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- NFC desk tag -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature android:name="android.hardware.nfc" android:required="true" />

    <!-- Foreground service (keep alive) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Boot receiver (restart service after reboot) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Network (POST to VPS) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- HealthConnect (steps) -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />

    <!-- Persistent notification (non-dismissable when bankrupt) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock (keep service alive during sync) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:name=".ProductivityApp"
        android:allowBackup="false"
        android:usesCleartextTraffic="true"
        android:icon="@android:mipmap/sym_def_app_icon"
        android:label="Productivity Economy"
        android:theme="@style/Theme.ProductivityApp">

        <!-- ── Main setup Activity (minimal UI) ───────────────────── -->
        <activity
            android:name=".PermissionSetupActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- HealthConnect Rationale Intent Filter -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Health Connect Rationale Alias (Android 14+) -->
        <activity-alias
            android:name=".ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".PermissionSetupActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- NFC tap lands here when app is in foreground -->
        <activity
            android:name=".NfcDispatchActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/com.productivityapp.desktag" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.TAG_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- ── Foreground Service (the heartbeat) ─────────────────── -->
        <service
            android:name=".MainForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ── AccessibilityService (real-time distraction tracking) ──────── -->
        <!--
            IMPORTANT: User must manually enable in
            Settings → Accessibility → Installed Services → Productivity Economy
            The PermissionSetupActivity guides them there.
            Permission: BIND_ACCESSIBILITY_SERVICE (system-level)
        -->
        <service
            android:name=".AppSessionTracker"
            android:exported="true"
            android:label="Distraction Time Tracker"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

        <!-- ── Notification Listener (UPI interception) ───────────── -->
        <!--
            IMPORTANT: User must manually enable in
            Settings → Notifications → Notification Access
            The setup Activity guides them there.
        -->
        <service
            android:name=".UpiNotificationListener"
            android:exported="true"
            android:label="UPI Expense Tracker"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
            <!-- Restrict to UPI apps only (battery optimization) -->
            <meta-data
                android:name="android.service.notification.default_filter_types"
                android:value="conversations|alerting" />
        </service>

        <!-- ── SMS Broadcast Receiver (bank SMS fallback) ─────────── -->
        <receiver
            android:name=".SmsBroadcastReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- ── Boot Receiver (restart foreground service) ─────────── -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- HealthConnect integration declaration -->
        <activity
            android:name="androidx.health.connect.client.PermissionController"
            android:exported="true" />

    </application>
</manifest>
